#!/bin/sh

# Personal data guard — block commits containing personal/company patterns
PATTERNS_FILE="$(git rev-parse --show-toplevel)/.personal-patterns"

if [ -f "$PATTERNS_FILE" ]; then
  TMPFILE=$(mktemp)
  git diff --cached --name-only | while IFS= read -r file; do
    [ -f "$file" ] || continue
    case "$file" in
      *.png|*.jpg|*.gif|*.ico|*.woff*|*.ttf|package-lock.json) continue ;;
    esac
    while IFS= read -r pattern; do
      [ -z "$pattern" ] && continue
      case "$pattern" in \#*) continue ;; esac
      if git show ":$file" 2>/dev/null | grep -qiE "$pattern"; then
        echo "  BLOCKED: $file matches '$pattern'" >> "$TMPFILE"
      fi
    done < "$PATTERNS_FILE"
  done

  if [ -s "$TMPFILE" ]; then
    echo ""
    echo "Personal data detected in staged files:"
    cat "$TMPFILE"
    echo ""
    echo "Replace personal data with generic placeholders before committing."
    echo "To bypass (emergency only): git commit --no-verify"
    rm -f "$TMPFILE"
    echo ""
    exit 1
  fi
  rm -f "$TMPFILE"
fi
