{
  "name": "feed-the-machine",
  "version": "1.7.0",
  "description": "A unified intelligence layer for Claude Code — 22 skills with OODA-based reasoning, persistent memory, multi-model deliberation, and optional operator cockpit inbox",
  "license": "MIT",
  "author": "kkudumu",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kkudumu/feed-the-machine.git"
  },
  "homepage": "https://github.com/kkudumu/feed-the-machine",
  "keywords": [
    "claude-code",
    "ai-agents",
    "skills",
    "ooda",
    "multi-model",
    "blackboard-architecture",
    "agentic"
  ],
  "bin": {
    "feed-the-machine": "bin/install.mjs"
  },
  "files": [
    "bin/",
    "hooks/",
    "docs/HOOKS.md",
    "install.sh",
    "uninstall.sh",
    "ftm.yml",
    "ftm-*.yml",
    "ftm/",
    "ftm-mind/",
    "ftm-executor/",
    "ftm-debug/",
    "ftm-brainstorm/",
    "ftm-audit/",
    "ftm-council/",
    "ftm-codex-gate/",
    "ftm-retro/",
    "ftm-intent/",
    "ftm-diagram/",
    "ftm-browse/",
    "ftm-git/",
    "ftm-pause/",
    "ftm-resume/",
    "ftm-upgrade/",
    "ftm-config/",
    "ftm-researcher/",
    "ftm-map/",
    "ftm-dashboard/",
    "ftm-routine/",
    "ftm-capture/",
    "ftm-state/",
    "ftm-inbox/",
    "ftm-config.default.yml",
    "ftm-manifest.json",
    "docs/INBOX.md",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "generate-manifest": "node bin/generate-manifest.mjs"
  },
  "dependencies": {
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.1",
    "ajv-cli": "^5.0.0",
    "husky": "^9.1.7",
    "promptfoo": "^0.100.0",
    "semantic-release": "^24.2.3"
  }
}
