# Large binaries — distribute via GitHub releases
ftm-browse/bin/ftm-browse

# Node modules — install via npm/bun
**/node_modules/

# User-specific runtime state (templates are committed, runtime data is not)
# ftm-state/ templates ARE committed — they're empty schemas
# But if someone runs locally, don't track their actual data

# Python artifacts
**/__pycache__/
*.pyc
**/.venv/
**/.ftm-map/

# Environment secrets
.env

# macOS
.DS_Store

# Worktrees (ftm-executor isolation)
.worktrees/

# Eval results
evals/results/

# Editors
.vscode/
.idea/

# ftm-browse persistent session data (cookies, local storage, etc.)
# Never commit — contains user credentials and auth tokens
ftm-browse/user-data/
~/.ftm-browse/user-data/
.personal-patterns
