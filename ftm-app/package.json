{
  "name": "ftm-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Feed The Machine \u2014 monorepo workspace",
  "scripts": {
    "dev": "pnpm -r run dev",
    "dev:electron": "pnpm --filter ftm-desktop run dev",
    "dev:daemon": "tsx packages/daemon/src/start.ts",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "setup:launchd": "tsx scripts/launchd-plist.ts",
    "setup:systemd": "tsx scripts/systemd-service.ts",
    "legacy-install": "tsx scripts/legacy-install.ts"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "electron"
    ]
  }
}